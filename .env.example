# AEGIS Environment Variables — copy this to .env and fill in your values
# DO NOT commit .env — it contains secrets

# ── Gemini AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── ECDSA Passport Signing ───────────────────────────────────────────────────
# Generate with: python scripts/generate_keys.py
AEGIS_ECDSA_PRIVATE_KEY=your_ecdsa_private_key_pem_here

# ── WhatsApp Alerts (CallMeBot — free) ───────────────────────────────────────
# Register at https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_PHONE=+91XXXXXXXXXX
CALLMEBOT_APIKEY=your_callmebot_api_key

# ── WhatsApp Alerts (Twilio — optional fallback) ─────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# ── Database ─────────────────────────────────────────────────────────────────
# Default: SQLite (local dev). For production use PostgreSQL.
DATABASE_URL=sqlite:///./aegis.db

# ── Risk Thresholds ──────────────────────────────────────────────────────────
ESCALATION_RISK_THRESHOLD=0.65
